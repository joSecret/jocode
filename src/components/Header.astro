---
import HeaderLink from './HeaderLink.astro';
import SocialList from './block-social/SocialList.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <nav>
    <h2><a href='/jocode'>{SITE_TITLE}</a></h2>
    <div class='internal-links'>
      <HeaderLink href='/jocode'>Home</HeaderLink>
      <HeaderLink href='/jocode/blog'>Blog</HeaderLink>
      <HeaderLink href='/jocode/documentation'>Docs</HeaderLink>
      <HeaderLink href='/jocode/snippets'>Snippets</HeaderLink>
      <HeaderLink href='/jocode/about'>About</HeaderLink>
    </div>

    <SocialList />
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: white;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
  }
  h2 {
    margin: 0;
    font-size: 1em;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  nav a {
    padding: 1em 0.5em;
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
</style>
