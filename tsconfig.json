{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@styles/*": ["src/assets/styles/*"],
      "@stylesComponents/*": ["src/assets/styles/components/*"],
      "@layout/*": ["src/layouts/*"],
    }
  }
}
